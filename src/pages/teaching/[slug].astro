---
// src/pages/teaching/[slug].astro
import { getCollection, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "../../layouts/MainGridLayout.astro";

// Create static routes for every teaching entry
export async function getStaticPaths() {
	const entries = await getCollection("teaching");
	return entries.map((entry) => ({
		params: { slug: entry.id.replace(/\.md$/, "") },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { slug } = Astro.params;

const { Content } = await render(entry);
const title = entry.data?.title ?? slug;
---
<MainGridLayout title={title} description={entry.data?.summary ?? title}>
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full ">
      <h1 class="text-3xl font-bold mb-4">{title}</h1>

      {entry.data?.date ? <div class="text-sm opacity-60 mb-4">Date: {entry.data.date}</div> : null}

      <Markdown class="">
        <Content />
      </Markdown>
    </div>
  </div>
</MainGridLayout>
