				course: "General Relativity (Masters Core)",
				term: "Summer 2021",
			},
		],
	},
	{
		institution: "Queen's University",
		roles: [
			{
				position: "Graduate Teaching Assistant",
				course: "PHYS 344: Intro to Quantum Mechanics",
				term: "Fall 2024",
			},
			{
				position: "Graduate Teaching Assistant",
				course: "PHYS 823: Intro to General Relativity",
