---

<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
    <!-- Bio -->
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>

    <!-- CV Sections -->
    <div class="flex flex-col gap-4 mt-4">

        <!-- Education (open by default) -->
        <details class="card-base rounded-[var(--radius-large)] overflow-hidden group" open>
            <summary class="px-9 py-5 cursor-pointer flex items-center justify-between select-none list-none">
                <span class="text-xl font-bold text-[var(--primary)]">Education</span>
                <svg class="w-5 h-5 text-[var(--primary)] transition-transform duration-300 group-open:rotate-180"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
            </summary>
            <div class="px-9 pb-6 flex flex-col gap-5">
                {education.map((e) => (
                    <div class="pl-4 border-l-2 border-[var(--primary)]">
                        <div class="flex flex-wrap items-baseline gap-x-2">
                            <span class="font-semibold text-[var(--primary)]">
                                <a href={e.url} target="_blank" rel="noopener" class="hover:underline">{e.degree}</a>
                            </span>
                            <span class="text-black/60 dark:text-white/60">·</span>
                            <span class="text-black/60 dark:text-white/60">{e.institution}, {e.location}</span>
                            <span class="text-sm text-black/40 dark:text-white/40 ml-auto">{e.period}</span>
                        </div>
                        <p class="text-sm text-black/60 dark:text-white/60 mt-1">{e.detail}</p>
                    </div>
                ))}
            </div>
        </details>

        <!-- Research -->
        <details class="card-base rounded-[var(--radius-large)] overflow-hidden group">
            <summary class="px-9 py-5 cursor-pointer flex items-center justify-between select-none list-none">
                <span class="text-xl font-bold text-[var(--primary)]">Research</span>
                <svg class="w-5 h-5 text-[var(--primary)] transition-transform duration-300 group-open:rotate-180"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
            </summary>
            <div class="px-9 pb-6 flex flex-col gap-5">
                {research.map((r) => (
                    <div class="pl-4 border-l-2 border-[var(--primary)]">
                        <div class="flex flex-wrap items-baseline gap-x-2">
                            <span class="font-semibold text-[var(--primary)]">{r.role}</span>
                            <span class="text-black/60 dark:text-white/60">·</span>
                            <span class="text-black/60 dark:text-white/60">
                                <a href={r.url} target="_blank" rel="noopener" class="hover:underline">{r.group}</a>
                            </span>
                            <span class="text-sm text-black/40 dark:text-white/40 ml-auto">{r.period}</span>
                        </div>
                        <p class="text-sm text-black/60 dark:text-white/60 mt-1">{r.detail}</p>
                    </div>
                ))}
            </div>
        </details>

        <!-- Teaching -->
        <details id="teaching" class="card-base rounded-[var(--radius-large)] overflow-hidden group">
            <summary class="px-9 py-5 cursor-pointer flex items-center justify-between select-none list-none">
                <span class="text-xl font-bold text-[var(--primary)]">Teaching</span>
                <svg class="w-5 h-5 text-[var(--primary)] transition-transform duration-300 group-open:rotate-180"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
            </summary>
            <div class="px-9 pb-6 flex flex-col gap-7">
                {teaching.map((t) => (
                    <div>
                        <h3 class="font-semibold text-[var(--primary)] mb-3">{t.institution}</h3>
                        <div class="flex flex-col gap-4">
                            {t.roles.map((r) => (
                                <div class="pl-4 border-l-2 border-[var(--primary)]">
                                    <div class="flex flex-wrap items-baseline gap-x-2">
                                        <span class="text-sm font-bold text-black/80 dark:text-white/80">{r.course}</span>
                                        <span class="text-xs text-black/40 dark:text-white/40">· {r.term}</span>
                                        {r.position === "Head Teaching Assistant" && (
                                            <span class="text-[10px] uppercase tracking-wider font-bold px-1.5 py-0.5 rounded bg-[var(--primary)] text-white ml-2">
                                                Head Position
                                            </span>
                                        )}
                                    </div>
                                    <div class="text-xs text-[var(--primary)] font-medium mt-0.5 mb-1">{r.position}</div>
                                    {r.detail && <p class="text-xs text-black/60 dark:text-white/60 leading-relaxed">{r.detail}</p>}
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </details>

    </div>
</MainGridLayout>

<script>
    // Handles direct URL loads of /about/?open=teaching (Swup navigation is handled in Layout.astro)
    const params = new URLSearchParams(window.location.search);
    if (params.get('open') === 'teaching') {
        const el = document.getElementById('teaching');
        if (el) {
            (el as HTMLDetailsElement).open = true;
            setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'start' }), 150);
        }
    }
</script>
