		degree: "Ph.D. Physics",
		institution: "Queen's University",
		location: "Canada",
		period: "2023 – present",
		detail:
			"Supervised by Prof. Joseph Bramante. Research in dark matter capture in neutron star cores (CFL phase of quark matter) and the CATCHY experiment. Hosted at the Arthur B. McDonald Canadian Astroparticle Physics Research Institute.",
		url: "https://www.queensu.ca/physics/",
	},
	{
		degree: "M.Sc. Physics",
		institution: "Heidelberg University",
		location: "Germany",
		period: "Sep 2022",
		detail:
			'Thesis: "Axion Basinschein: A search for gravitationally bound solar axions via stimulated decay into photons." Research performed at McGill University under Prof. Katelin Schutz. Grade: 1.1 (Very Good). Overall GPA: 1.3 (Very Good).',
		url: "https://www.physik.uni-heidelberg.de/?lang=en",
	},
	{
		degree: "B.Sc. Physics",
		institution: "Leipzig University",
		location: "Germany",
		period: "Jul 2019",
		detail:
			'Thesis: "Black Holes, Singularity Theorems and The Global Structure of Spacetime." A+ in all mandatory theoretical physics courses.',
		url: "https://www.physgeo.uni-leipzig.de/en",
	},
];

const research = [
	{
		role: "PhD Researcher",
		group: "QHEAT Group, Queen's University",
		period: "2023 – present",
		detail:
			"Dark matter capture in neutron stars (Color-Flavor-Locked quark matter), the CATCHY experiment (Coherent Atomic Transitions from Counterpropagating pulsed HYdrogen), and early universe cosmology. Supervised by Prof. Joseph Bramante.",
