				term: "Fall 2023",
			},
			{
				position: "Graduate Teaching Assistant",
				course: "APSC 112: Physics II",
				term: "Winter 2023",
			},
			{
				position: "Graduate Teaching Assistant",
				course: "APSC Lab 102: Introduction to Experimentation and Design",
				term: "Summer 2023",
			},
			{
				position: "Graduate Teaching Assistant",
				course: "PHYS 490: Nuclear and Particle Physics",
				term: "Fall 2022",
			},
			{
				position: "Lab Supervisor",
				course: "APSC Lab 102: Introduction to Experimentation and Design",
				term: "Fall 2022",
			},
		],
	},
	{
		institution: "Leipzig University",
		roles: [
			{
				position: "Head Teaching Assistant",
				course: "Mechanics II & Electrodynamics II (Theoretical Physics III)",
				term: "Winter 2019",
				detail: "Redesigned course materials and conducted weekly plenary tutorials for the theoretical physics track.",
			},
